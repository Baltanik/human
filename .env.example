# Copy this file to .env and fill in all values before deploying.

# ── Backend ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_64_char_random_hex

# Admin login credentials
ADMIN_EMAIL=admin@yourdomain.com
# Generate bcrypt hash with:
#   node -e "import('bcryptjs').then(m=>console.log(m.default.hashSync('yourpassword',12)))"
ADMIN_PASSWORD_HASH=$2b$12$replaceme

# CORS origin — your production domain (no trailing slash)
CORS_ORIGIN=https://yourdomain.com

# SQLite DB file path inside the container
DB_PATH=/app/data/human.db

# ── Frontend (Vite build-time) ────────────────────────────────────────────────
# Leave unset or empty: browser calls /api/* on the same host (Nginx or Vite proxy).
# Set only if the API is on another origin, e.g. https://api.rewido.it
# VITE_API_URL=https://api.rewido.it
